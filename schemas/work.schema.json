{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdt.dev/schemas/work_instruction.schema.json",
  "title": "WorkInstruction",
  "description": "A work instruction for operators",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "created",
    "author"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^WORK-[0-9A-Z]{26}$",
      "description": "Unique identifier (WORK prefix + ULID)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short descriptive title"
    },
    "document_number": {
      "type": "string",
      "description": "Document number (e.g., WI-MACH-015)"
    },
    "revision": {
      "type": "string",
      "description": "Document revision"
    },
    "description": {
      "type": "string",
      "description": "Purpose/description"
    },
    "safety": {
      "type": "object",
      "properties": {
        "ppe_required": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "item": {
                "type": "string"
              },
              "standard": {
                "type": "string"
              }
            }
          }
        },
        "hazards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hazard": {
                "type": "string"
              },
              "control": {
                "type": "string"
              }
            }
          }
        }
      },
      "description": "Safety requirements"
    },
    "tools_required": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "part_number": {
            "type": "string"
          }
        }
      },
      "description": "Tools needed"
    },
    "materials_required": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "specification": {
            "type": "string"
          }
        }
      },
      "description": "Materials needed"
    },
    "procedure": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": {
            "type": "integer"
          },
          "action": {
            "type": "string"
          },
          "verification": {
            "type": [
              "string",
              "null"
            ]
          },
          "caution": {
            "type": [
              "string",
              "null"
            ]
          },
          "image": {
            "type": [
              "string",
              "null"
            ]
          },
          "estimated_time_minutes": {
            "type": [
              "number",
              "null"
            ]
          },
          "approval": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "requires_signoff": {
                "type": "boolean",
                "description": "Require sign-off after this step"
              },
              "min_approvals": {
                "type": "integer",
                "default": 1,
                "description": "Minimum number of approvals required"
              },
              "required_roles": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Roles that can approve (engineering, quality, management, admin)"
              },
              "required_approvers": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Specific team members who must approve"
              },
              "require_signature": {
                "type": "boolean",
                "description": "Require digital signature (21 CFR Part 11)"
              },
              "hold_point": {
                "type": "boolean",
                "description": "Quality hold point - production stops until approved"
              }
            },
            "description": "Approval requirements for this step (electronic router)"
          },
          "data_fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "key",
                "label"
              ],
              "properties": {
                "key": {
                  "type": "string",
                  "description": "Field key/name"
                },
                "label": {
                  "type": "string",
                  "description": "Human-readable label"
                },
                "data_type": {
                  "type": "string",
                  "enum": [
                    "text",
                    "number",
                    "boolean",
                    "select"
                  ],
                  "default": "text"
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "units": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Units for numeric fields"
                },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Allowed values for select type"
                }
              }
            },
            "description": "Data fields to collect at this step"
          },
          "equipment": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Equipment/tools required for this step (serial numbers collected at execution)"
          }
        }
      },
      "description": "Step-by-step procedure"
    },
    "quality_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "at_step": {
            "type": "integer"
          },
          "characteristic": {
            "type": "string"
          },
          "specification": {
            "type": "string"
          }
        }
      },
      "description": "In-process quality checks"
    },
    "estimated_duration_minutes": {
      "type": [
        "number",
        "null"
      ],
      "description": "Total estimated time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for filtering"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "released",
        "obsolete"
      ],
      "description": "Current status"
    },
    "links": {
      "type": "object",
      "properties": {
        "process": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              },
              "required": [
                "id"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "description": "Parent process ID"
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          },
          "description": "IDs of related control plan items"
        }
      }
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "author": {
      "type": "string",
      "description": "Author name"
    },
    "entity_revision": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Entity revision number"
    }
  },
  "additionalProperties": true
}
